{
    "manifest_version":3,
    "name": "Focus RPG",
    "version": "2.0.0",
    "description": "Track your focus habits and earn points for productive browsing",
    "icons":{
        "16": "assets/icons/icon16.png",
        "48":"assets/icons.icon46.png",
        "128":"assets/icons/icon128.png"
    },
    "background": {
        "service_worker":"background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js":["content.js"],
            "run_at": "document_idle"
        }
    ],
    "side_panel": {
        "default_path":"sidepanel/panel.html"
    },
    "permissions": [
        "storage",
        "tabs",
        "sidePanel",
        "alarms"
    ],
    "host_permissions": ["<all_urls>"],
    "action": {
        "default_title":"Focus RPG"
    }
}